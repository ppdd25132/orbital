# Get your API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google OAuth / NextAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# P-038 durable trust foundation
# Any standard Postgres URL works, including Neon, Supabase, or Vercel Postgres.
ORBITAL_DATABASE_URL=postgres://user:password@host:5432/database
ORBITAL_TOKEN_SECRET=replace-with-a-long-random-token-encryption-secret
CRON_SECRET=replace-with-a-long-random-cron-secret

# Debug route stays disabled unless explicitly enabled.
ORBITAL_ENABLE_DEBUG_ENV=false
ORBITAL_ADMIN_EMAIL=you@example.com
